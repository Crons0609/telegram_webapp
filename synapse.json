[
    {
        "name": "Synapse Bot - Telegram Handler",
        "nodes": [
            {
                "parameters": {
                    "path": "telegram",
                    "responseMode": "onReceived",
                    "options": {}
                },
                "id": "telegram-webhook",
                "name": "Telegram Webhook",
                "type": "n8n-nodes-base.webhook",
                "typeVersion": 1,
                "position": [
                    250,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "getDocument",
                    "collection": "users",
                    "documentId": "={{ $json.message.chat.id }}",
                    "options": {}
                },
                "id": "firebase-get-user",
                "name": "Firebase: Get User",
                "type": "n8n-nodes-base.firebase",
                "typeVersion": 1,
                "position": [
                    450,
                    300
                ]
            },
            {
                "parameters": {
                    "jsCode": "const chatId = $input.first().json.message?.chat?.id;\nconst text = $input.first().json.message?.text;\nconst callbackData = $input.first().json.callback_query?.data;\nconst isCallback = !!callbackData;\n\n// If it's a callback (button click) handle differently\nif (isCallback) {\n  return [{\n    chatId: $input.first().json.callback_query.message.chat.id,\n    callbackId: $input.first().json.callback_query.id,\n    data: callbackData,\n    messageId: $input.first().json.callback_query.message.message_id\n  }];\n}\n\n// Regular text command\nlet command = '';\nlet args = '';\nif (text && text.startsWith('/')) {\n  const parts = text.split(' ');\n  command = parts[0];\n  args = parts.slice(1).join(' ');\n}\n\nreturn [{\n  chatId,\n  command,\n  args,\n  text,\n  isCallback: false\n}];"
                },
                "id": "parse-input",
                "name": "Parse Input",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    650,
                    300
                ]
            },
            {
                "parameters": {
                    "conditions": {
                        "string": [
                            {
                                "value1": "={{ $json.isCallback }}",
                                "operation": "equals",
                                "value2": true
                            }
                        ]
                    }
                },
                "id": "if-callback",
                "name": "Is Callback?",
                "type": "n8n-nodes-base.if",
                "typeVersion": 1,
                "position": [
                    850,
                    300
                ]
            },
            {
                "parameters": {
                    "jsCode": "const chatId = $input.first().json.chatId;\nconst callbackId = $input.first().json.callbackId;\nconst data = $input.first().json.data;\nconst messageId = $input.first().json.messageId;\n\n// Handle different callback actions\nlet newState = {};\nlet answer = '';\n\nif (data.startsWith('vice_')) {\n  const vice = data.replace('vice_', '');\n  // Store chosen vice and generate invite link\n  newState.vice = vice;\n  newState.phase = 'inviting_helpers';\n  \n  // Create unique invite link (e.g., bot username?start=invite_<userId>)\n  const inviteLink = `https://t.me/YourBotUsername?start=invite_${chatId}`;\n  answer = `Has elegido *${vice}*.\\n\\nPara que puedas recibir ayuda, comparte este enlace con hasta 2 personas que te apoyarán:\\n\\n${inviteLink}\\n\\nCuando ellos inicien el bot con ese enlace, quedarán registrados como tus ayudantes.\\n\\nMientras tanto, comenzaré a enviarte mensajes de aliento y pequeñas misiones.`;\n} else if (data.startsWith('task_')) {\n  // Task completion: taskId, points\n  const [_, taskId, points] = data.split('_');\n  // Update user's points and mark task as done in Firebase\n  // We'll handle in Firebase node later\n  answer = `✅ Tarea completada. ¡Has ganado ${points} puntos!`;\n  newState.lastTaskCompletion = Date.now();\n} else if (data === 'help') {\n  answer = 'Ayuda: ...';\n}\n\nreturn [{\n  chatId,\n  callbackId,\n  answer,\n  newState,\n  data\n}];"
                },
                "id": "handle-callback",
                "name": "Handle Callback",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1050,
                    200
                ]
            },
            {
                "parameters": {
                    "jsCode": "const chatId = $input.first().json.chatId;\nconst command = $input.first().json.command;\nconst args = $input.first().json.args;\n\nlet responseText = '';\nlet updateUser = false;\nlet userData = {};\n\nif (command === '/start') {\n  // Check if it's a helper invite (start=invite_<userId>)\n  if (args.startsWith('invite_')) {\n    const addictId = args.replace('invite_', '');\n    // Register current user as helper for addictId\n    // We'll store helper info in Firebase\n    responseText = `¡Gracias por ayudar! Ahora recibirás recordatorios para apoyar a la persona que está dejando su vicio.`;\n    updateUser = true;\n    userData = { role: 'helper', addictId };\n  } else {\n    // New addict: show vice selection buttons\n    responseText = 'Bienvenido a Synapse. Elige el vicio que quieres erradicar:';\n    // Buttons will be sent after this node\n    updateUser = true;\n    userData = { role: 'addict', phase: 'choose_vice' };\n  }\n} else if (command === '/status') {\n  // Show points, streak, etc. (fetch from Firebase later)\n  responseText = 'Obteniendo tu progreso...';\n}\n\nreturn [{\n  chatId,\n  responseText,\n  updateUser,\n  userData,\n  command,\n  args\n}];"
                },
                "id": "handle-command",
                "name": "Handle Command",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1050,
                    400
                ]
            },
            {
                "parameters": {
                    "conditions": {
                        "string": [
                            {
                                "value1": "={{ $json.updateUser }}",
                                "operation": "equals",
                                "value2": true
                            }
                        ]
                    }
                },
                "id": "if-update-user",
                "name": "Update User?",
                "type": "n8n-nodes-base.if",
                "typeVersion": 1,
                "position": [
                    1250,
                    400
                ]
            },
            {
                "parameters": {
                    "operation": "createDocument",
                    "collection": "users",
                    "documentId": "={{ $json.chatId }}",
                    "dataToSend": "defineBelow",
                    "dataFields": {
                        "properties": [
                            {
                                "name": "role",
                                "value": "={{ $json.userData.role }}"
                            },
                            {
                                "name": "phase",
                                "value": "={{ $json.userData.phase }}"
                            },
                            {
                                "name": "addictId",
                                "value": "={{ $json.userData.addictId }}",
                                "includeInFields": "={{ $json.userData.addictId ? true : false }}"
                            },
                            {
                                "name": "registeredAt",
                                "value": "={{ Date.now() }}"
                            },
                            {
                                "name": "points",
                                "value": 0
                            },
                            {
                                "name": "streak",
                                "value": 0
                            }
                        ]
                    },
                    "options": {
                        "merge": true
                    }
                },
                "id": "firebase-create-user",
                "name": "Firebase: Save User",
                "type": "n8n-nodes-base.firebase",
                "typeVersion": 1,
                "position": [
                    1450,
                    400
                ]
            },
            {
                "parameters": {
                    "resource": "message",
                    "operation": "sendMessage",
                    "chatId": "={{ $json.chatId }}",
                    "text": "={{ $json.responseText || $json.answer }}",
                    "additionalFields": {
                        "replyMarkup": "={{ $json.command === '/start' && !$json.userData.addictId ? { inline_keyboard: [[{ text: '🚬 Cigarro', callback_data: 'vice_cigarro' }, { text: '💊 Crack', callback_data: 'vice_crack' }], [{ text: '🌿 Marihuana', callback_data: 'vice_marihuana' }, { text: '🍷 Alcohol', callback_data: 'vice_alcohol' }], [{ text: '☕ Café', callback_data: 'vice_cafe' }, { text: '💊 Pastillas', callback_data: 'vice_pastillas' }], [{ text: '🍔 Problemas alimenticios', callback_data: 'vice_alimentacion' }]] } : undefined }}"
                    }
                },
                "id": "telegram-send",
                "name": "Telegram: Send Message",
                "type": "n8n-nodes-base.telegram",
                "typeVersion": 1,
                "position": [
                    1650,
                    400
                ]
            },
            {
                "parameters": {
                    "method": "POST",
                    "url": "https://api.telegram.org/bot{{$credentials.telegramApi.token}}/answerCallbackQuery",
                    "authentication": "none",
                    "sendHeaders": false,
                    "sendBody": true,
                    "bodyParameters": {
                        "parameters": [
                            {
                                "name": "callback_query_id",
                                "value": "={{ $json.callbackId }}"
                            },
                            {
                                "name": "text",
                                "value": "={{ $json.answer }}"
                            }
                        ]
                    },
                    "options": {}
                },
                "id": "telegram-answer-callback",
                "name": "Telegram: Answer Callback",
                "type": "n8n-nodes-base.httpRequest",
                "typeVersion": 1,
                "position": [
                    1250,
                    200
                ]
            }
        ],
        "connections": {
            "Telegram Webhook": {
                "main": [
                    [
                        {
                            "node": "Parse Input",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Parse Input": {
                "main": [
                    [
                        {
                            "node": "Is Callback?",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Is Callback?": {
                "main": [
                    [
                        {
                            "node": "Handle Callback",
                            "type": "main",
                            "index": 0
                        }
                    ],
                    [
                        {
                            "node": "Handle Command",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Handle Callback": {
                "main": [
                    [
                        {
                            "node": "Telegram: Answer Callback",
                            "type": "main",
                            "index": 0
                        }
                    ],
                    [
                        {
                            "node": "Firebase: Get User",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Handle Command": {
                "main": [
                    [
                        {
                            "node": "Is Update User?",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Is Update User?": {
                "main": [
                    [
                        {
                            "node": "Firebase: Create/Update User",
                            "type": "main",
                            "index": 0
                        }
                    ],
                    [
                        {
                            "node": "Telegram: Send Message",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Firebase: Create/Update User": {
                "main": [
                    [
                        {
                            "node": "Telegram: Send Message",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Telegram: Answer Callback": {
                "main": [
                    [
                        {
                            "node": "Firebase: Get User",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Firebase: Get User": {
                "main": [
                    [
                        {
                            "node": "Parse Input",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            }
        },
        "settings": {
            "executionOrder": "v1"
        }
    },
    {
        "name": "Synapse Bot - Scheduler",
        "nodes": [
            {
                "parameters": {
                    "rule": {
                        "interval": [
                            {
                                "field": "minutes",
                                "minutesInterval": 1
                            }
                        ]
                    }
                },
                "id": "schedule-trigger",
                "name": "Every 1 minute",
                "type": "n8n-nodes-base.scheduleTrigger",
                "typeVersion": 1,
                "position": [
                    250,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "getAll",
                    "collection": "users",
                    "returnAll": true,
                    "options": {
                        "where": "role == 'addict'"
                    }
                },
                "id": "firebase-get-addicts",
                "name": "Firebase: Get All Addicts",
                "type": "n8n-nodes-base.firebase",
                "typeVersion": 1,
                "position": [
                    450,
                    300
                ]
            },
            {
                "parameters": {
                    "jsCode": "const now = Date.now();\nconst users = $input.all();\nconst messagesToSend = [];\n\nusers.forEach(user => {\n  const addict = user.json;\n  const userId = addict.id; // chatId\n  const registeredAt = addict.registeredAt;\n  const daysSince = (now - registeredAt) / (1000 * 3600 * 24);\n  \n  // Determine message interval based on days since registration\n  let intervalMinutes = 3; // first day\n  if (daysSince >= 7) intervalMinutes = 10;\n  if (daysSince >= 14) intervalMinutes = 30;\n  if (daysSince >= 21) intervalMinutes = 60;\n  if (daysSince >= 60) intervalMinutes = 120;\n  \n  // Get last message time from user's data\n  const lastMessage = addict.lastMessageTime || 0;\n  const nextAllowed = lastMessage + intervalMinutes * 60 * 1000;\n  \n  if (now >= nextAllowed) {\n    // Also check if it's night (more frequent) – for simplicity we just send\n    // In a real implementation you could reduce interval at night\n    messagesToSend.push({\n      chatId: userId,\n      type: 'encouragement',\n      text: '🌱 Sigue así, cada día es un paso adelante. ¡Tú puedes!'\n    });\n    // Update last message time in a separate node\n  }\n  \n  // Check for scheduled missions (pills, etc.) – stored in Firebase as tasks\n  // For brevity, we fetch tasks from another collection\n});\n\nreturn messagesToSend;"
                },
                "id": "check-messages",
                "name": "Check Messages Due",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    650,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "getAll",
                    "collection": "missions",
                    "returnAll": true,
                    "options": {
                        "where": "active == true"
                    }
                },
                "id": "firebase-get-missions",
                "name": "Firebase: Get Active Missions",
                "type": "n8n-nodes-base.firebase",
                "typeVersion": 1,
                "position": [
                    650,
                    450
                ]
            },
            {
                "parameters": {
                    "jsCode": "const now = Date.now();\nconst missions = $input.all();\nconst messagesToSend = [];\n\nmissions.forEach(mission => {\n  const m = mission.json;\n  const scheduledTime = m.scheduledTime; // timestamp for next occurrence\n  if (now >= scheduledTime && !m.sent) {\n    // Send to addict\n    messagesToSend.push({\n      chatId: m.addictId,\n      type: 'mission',\n      text: m.description,\n      inlineKeyboard: [[{ text: '✅ Completar', callback_data: `task_${m.id}_${m.points}` }]]\n    });\n    // Also send to helpers (if any)\n    if (m.helpers && m.helpers.length) {\n      m.helpers.forEach(helperId => {\n        messagesToSend.push({\n          chatId: helperId,\n          type: 'reminder',\n          text: `Recuerda a ${m.addictName} que debe: ${m.description}`,\n          inlineKeyboard: [[{ text: '📞 Llamar', callback_data: `remind_${m.id}` }]]\n        });\n      });\n    }\n    // Mark as sent (will be updated in Firebase)\n    m.sent = true;\n  }\n});\n\nreturn messagesToSend;"
                },
                "id": "check-missions",
                "name": "Check Missions Due",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    850,
                    300
                ]
            },
            {
                "parameters": {
                    "resource": "message",
                    "operation": "sendMessage",
                    "chatId": "={{ $json.chatId }}",
                    "text": "={{ $json.text }}",
                    "additionalFields": {
                        "replyMarkup": "={{ $json.inlineKeyboard ? JSON.stringify({ inline_keyboard: $json.inlineKeyboard }) : undefined }}"
                    }
                },
                "id": "telegram-send-scheduled",
                "name": "Telegram: Send Scheduled Message",
                "type": "n8n-nodes-base.telegram",
                "typeVersion": 1,
                "position": [
                    1050,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "updateDocument",
                    "collection": "users",
                    "documentId": "={{ $json.chatId }}",
                    "dataToSend": "defineBelow",
                    "dataFields": {
                        "properties": [
                            {
                                "name": "lastMessageTime",
                                "value": "={{ Date.now() }}"
                            }
                        ]
                    },
                    "options": {
                        "merge": true
                    }
                },
                "id": "firebase-update-last-message",
                "name": "Firebase: Update Last Message Time",
                "type": "n8n-nodes-base.firebase",
                "typeVersion": 1,
                "position": [
                    1050,
                    450
                ]
            }
        ],
        "connections": {
            "Every 1 minute": {
                "main": [
                    [
                        {
                            "node": "Firebase: Get All Addicts",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Firebase: Get All Addicts": {
                "main": [
                    [
                        {
                            "node": "Check Messages Due (encouragement)",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Check Messages Due (encouragement)": {
                "main": [
                    [
                        {
                            "node": "Firebase: Get Active Missions",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Firebase: Get Active Missions": {
                "main": [
                    [
                        {
                            "node": "Check Missions Due",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Check Missions Due": {
                "main": [
                    [
                        {
                            "node": "Telegram: Send Scheduled Message",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            },
            "Telegram: Send Scheduled Message": {
                "main": [
                    [
                        {
                            "node": "Firebase: Update Last Message Time",
                            "type": "main",
                            "index": 0
                        }
                    ]
                ]
            }
        },
        "settings": {
            "executionOrder": "v1"
        }
    }
]